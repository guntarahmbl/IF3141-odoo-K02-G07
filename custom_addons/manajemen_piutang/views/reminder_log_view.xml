<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reminder_log_tree" model="ir.ui.view">
        <field name="name">manajemen_piutang.reminder_log.tree</field>
        <field name="model">manajemen_piutang.reminder_log</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="waktu_kirim" string="Waktu Kirim"/>
                <field name="tagihan_id" string="Tagihan"/>
                <field name="konsumen_id" string="Konsumen"/>
                <field name="jenis_pengingat" string="Jenis Pengingat"/>
                <field name="status_kirim" string="Status Kirim"
                       widget="badge"
                       decoration-success="status_kirim == 'terkirim'"
                       decoration-danger="status_kirim == 'gagal'"/>
                <field name="keterangan_error" string="Keterangan Error"/>
            </tree>
        </field>
    </record>

    <record id="action_reminder_log" model="ir.actions.act_window">
        <field name="name">Log Reminder WhatsApp</field>
        <field name="res_model">manajemen_piutang.reminder_log</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
