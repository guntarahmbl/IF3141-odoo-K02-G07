<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_manajemen_tagihan_tree" model="ir.ui.view">
        <field name="name">manajemen.tagihan.tree</field>
        <field name="model">manajemen_piutang.tagihan</field>
        <field name="arch" type="xml">
            <tree string="Daftar Tagihan" decoration-danger="status_lunas=='belum_lunas'" decoration-success="status_lunas=='lunas'">
                <field name="konsumen_id"/>
                <field name="tgl_terbit"/>
                <field name="tgl_jatuh_tempo"/>
                <field name="total_tagihan" sum="Total Piutang"/>
                <field name="days_overdue"/>
                <field name="aging_bucket" widget="badge"/>
                <field name="status_lunas" widget="badge" decoration-success="status_lunas == 'lunas'" decoration-danger="status_lunas == 'belum_lunas'"/>
            </tree>
        </field>
    </record>

    <record id="view_manajemen_tagihan_search" model="ir.ui.view">
        <field name="name">manajemen.tagihan.search</field>
        <field name="model">manajemen_piutang.tagihan</field>
        <field name="arch" type="xml">
            <search string="Cari Tagihan">
                <field name="konsumen_id"/>
                <field name="status_lunas"/>
                <field name="tgl_terbit"/>
                <field name="tgl_jatuh_tempo"/>
                <separator/>
                <filter string="Belum Lunas" name="filter_belum_lunas" domain="[('status_lunas', '=', 'belum_lunas')]"/>
                <filter string="Lunas" name="filter_lunas" domain="[('status_lunas', '=', 'lunas')]"/>
                <filter string="Jatuh Tempo" name="filter_jatuh_tempo" domain="[('status_lunas', '=', 'belum_lunas'), ('tgl_jatuh_tempo', '&lt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Mendekati Jatuh Tempo" name="filter_due_soon" domain="[('status_lunas', '=', 'belum_lunas'), ('tgl_jatuh_tempo', '&gt;', context_today().strftime('%Y-%m-%d')), ('tgl_jatuh_tempo', '&lt;=', (context_today() + relativedelta(days=3)).strftime('%Y-%m-%d'))]"/>
                <filter string="Perlu Eskalasi" name="filter_eskalasi" domain="[('is_eskalasi', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status_lunas'}"/>
                    <filter string="Aging Piutang" name="group_by_aging" context="{'group_by': 'aging_bucket'}"/>
                    <filter string="Pelanggan" name="group_by_konsumen" context="{'group_by': 'konsumen_id'}"/>
                    <filter string="Bulan Terbit" name="group_by_tgl_terbit" context="{'group_by': 'tgl_terbit:month'}"/>
                    <filter string="Bulan Jatuh Tempo" name="group_by_jatuh_tempo" context="{'group_by': 'tgl_jatuh_tempo:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_manajemen_tagihan_graph_status" model="ir.ui.view">
        <field name="name">manajemen.tagihan.graph.status</field>
        <field name="model">manajemen_piutang.tagihan</field>
        <field name="arch" type="xml">
            <graph string="Dashboard Status Tagihan" type="bar">
                <field name="status_lunas"/>
                <field name="total_tagihan" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_manajemen_tagihan_pivot_dashboard" model="ir.ui.view">
        <field name="name">manajemen.tagihan.pivot.dashboard</field>
        <field name="model">manajemen_piutang.tagihan</field>
        <field name="arch" type="xml">
            <pivot string="Ringkasan Dashboard Tagihan" display_quantity="true">
                <field name="aging_bucket" type="row"/>
                <field name="status_lunas" type="col"/>
                <field name="total_tagihan" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_manajemen_tagihan_form" model="ir.ui.view">
        <field name="name">manajemen.tagihan.form</field>
        <field name="model">manajemen_piutang.tagihan</field>
        <field name="arch" type="xml">
            <form string="Form Tagihan">
                <header>
                    <button name="generateInvoice" string="Membuat E-Invoice" type="object" class="oe_highlight" invisible="status_lunas == 'lunas'"/>
                    <button name="kirim_reminder_wa" string="Kirim Reminder WA" type="object" class="oe_highlight" invisible="status_lunas == 'lunas'"/>
                    <field name="status_lunas" widget="statusbar" statusbar_visible="belum_lunas,lunas"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="konsumen_id"/>
                            <field name="tgl_terbit"/>
                            <field name="xendit_external_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="tgl_jatuh_tempo"/>
                            <field name="total_tagihan"/>
                            <field name="xendit_invoice_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rincian Item">
                            <field name="rincian_item" placeholder="Detail pesanan..."/>
                        </page>
                        <page string="Link Pembayaran">
                            <field name="link_payment" widget="url"/>
                        </page>
                        <page string="Riwayat Pembayaran">
                            <field name="pembayaran_ids">
                                <tree editable="bottom">
                                    <field name="id_transaksi"/>
                                    <field name="nominal_masuk"/>
                                    <field name="waktu_bayar"/>
                                    <field name="status_settlement"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_manajemen_tagihan" model="ir.actions.act_window">
        <field name="name">Daftar Tagihan</field>
        <field name="res_model">manajemen_piutang.tagihan</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_manajemen_tagihan_tree"/>
        <field name="search_view_id" ref="view_manajemen_tagihan_search"/>
    </record>

    <record id="action_analisis_tagihan" model="ir.actions.act_window">
        <field name="name">Analisis Tagihan</field>
        <field name="res_model">manajemen_piutang.tagihan</field>
        <field name="view_mode">graph,pivot,tree,form</field>
        <field name="view_id" ref="view_manajemen_tagihan_graph_status"/>
        <field name="search_view_id" ref="view_manajemen_tagihan_search"/>
        <field name="context">{'search_default_group_by_status': 1}</field>
    </record>
</odoo>
