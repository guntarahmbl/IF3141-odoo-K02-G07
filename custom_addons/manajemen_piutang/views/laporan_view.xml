<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_manajemen_laporan_pivot" model="ir.ui.view">
        <field name="name">manajemen.laporan.pivot</field>
        <field name="model">manajemen_piutang.tagihan</field>
        <field name="arch" type="xml">
            <pivot string="Laporan Piutang &amp; Arus Kas" display_quantity="true">
                <field name="konsumen_id" type="row"/>
                <field name="tgl_terbit" type="col" interval="month"/>
                <field name="total_tagihan" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_manajemen_laporan_graph" model="ir.ui.view">
        <field name="name">manajemen.laporan.graph</field>
        <field name="model">manajemen_piutang.tagihan</field>
        <field name="arch" type="xml">
            <graph string="Grafik Status Piutang" type="pie">
                <field name="status_lunas"/>
                <field name="total_tagihan" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_manajemen_laporan" model="ir.actions.act_window">
        <field name="name">Laporan Analitik Piutang</field>
        <field name="res_model">manajemen_piutang.tagihan</field>
        <field name="view_mode">pivot,graph,tree</field>
    </record>
</odoo>