<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pengaturan_log_tree" model="ir.ui.view">
        <field name="name">manajemen_piutang.pengaturan_log.tree</field>
        <field name="model">manajemen_piutang.pengaturan_log</field>
        <field name="arch" type="xml">
            <tree string="Log Audit Pengaturan" create="false" edit="false" delete="false">
                <field name="waktu_perubahan"/>
                <field name="user_id"/>
                <field name="field_name"/>
                <field name="old_value"/>
                <field name="new_value"/>
            </tree>
        </field>
    </record>

    <record id="action_pengaturan_log" model="ir.actions.act_window">
        <field name="name">Log Audit Pengaturan</field>
        <field name="res_model">manajemen_piutang.pengaturan_log</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
