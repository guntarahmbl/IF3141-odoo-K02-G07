<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_tagihan_staff_penagihan_eskalasi" model="ir.rule">
            <field name="name">Staff Penagihan hanya melihat tagihan eskalasi</field>
            <field name="model_id" ref="model_manajemen_piutang_tagihan"/>
            <field name="domain_force">[('is_eskalasi', '=', True)]</field>
            <field name="groups" eval="[(4, ref('manajemen_piutang.group_staff_penagihan'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_tagihan_admin_all" model="ir.rule">
            <field name="name">Administrator Sistem dapat melihat seluruh tagihan</field>
            <field name="model_id" ref="model_manajemen_piutang_tagihan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('manajemen_piutang.group_administrator_sistem'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
